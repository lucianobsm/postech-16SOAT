{
  "request": {
    "method": "POST",
    "url": "/auth/login",
    "bodyPatterns": [
      {
        "matchesJsonSchema": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "pattern": "invalid.*"
            }
          }
        }
      }
    ]
  },
  "response": {
    "status": 401,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "erro": "Usuário não encontrado: invalid@example.com"
    }
  }
}
